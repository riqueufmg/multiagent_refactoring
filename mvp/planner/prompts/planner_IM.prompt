      "files": ["..."],
      "ops": [
        {
          "op": "EXTRACT_CLASS",
          "inputs": ["..."],
          "outputs": ["..."],
          "details": "Create a responsibility-oriented class for the moved public-facing API.",
          "risk": "low|medium|high"
        },
        {
          "op": "MOVE_METHOD",
          "inputs": ["<public method from target class>"],
          "outputs": ["<method in extracted class>"],
          "details": "Move this public method out of the target class and remove the original method from the target class. Do not keep a delegating wrapper unless strictly required.",
          "risk": "low|medium|high"
        },
        {
          "op": "<allowed op>",
          "inputs": ["..."],
          "outputs": ["..."],
          "details": "...",
          "risk": "low|medium|high"
        }
