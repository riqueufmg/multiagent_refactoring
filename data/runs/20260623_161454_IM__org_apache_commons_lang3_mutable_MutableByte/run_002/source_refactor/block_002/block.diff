+package org.apache.commons.lang3.mutable;
+
+/**
+ * Helper class that encapsulates mutation and atomic-style operations for MutableByte.
+ * Operates via a MutableByteAccessor to avoid direct dependency on the MutableByte internals.
+ *
+ * This class owns the ARITH field that provides byte arithmetic operations.
+ */
+public class MutableByteAtomicOperations {
+
+    private final MutableByteAccessor accessor;
+
+    private static final ByteArithmetic ARITH = new MutableByteArithmetic();
+
+    public MutableByteAtomicOperations(final MutableByteAccessor accessor) {
+        this.accessor = accessor;
+    }
+
+    public void add(final byte operand) {
+        accessor.setRaw(ARITH.add(accessor.getRaw(), operand));
+    }
+
+    public void add(final Number operand) {
+        accessor.setRaw(ARITH.add(accessor.getRaw(), operand));
+    }
+
+    public byte addAndGet(final byte operand) {
+        final byte newVal = ARITH.addAndGet(accessor.getRaw(), operand);
+        accessor.setRaw(newVal);
+        return newVal;
+    }
+
+    public byte addAndGet(final Number operand) {
+        final byte newVal = ARITH.addAndGet(accessor.getRaw(), operand);
+        accessor.setRaw(newVal);
+        return newVal;
+    }
+
+    public byte getAndAdd(final byte operand) {
+        final byte current = accessor.getRaw();
+        final byte last = ARITH.getAndAdd(current, operand);
+        final byte newVal = ARITH.add(current, operand);
+        accessor.setRaw(newVal);
+        return last;
+    }
+
+    public byte getAndAdd(final Number operand) {
+        final byte current = accessor.getRaw();
+        final byte last = ARITH.getAndAdd(current, operand);
+        final byte newVal = ARITH.add(current, operand);
+        accessor.setRaw(newVal);
+        return last;
+    }
+
+    public void increment() {
+        accessor.setRaw(ARITH.increment(accessor.getRaw()));
+    }
+
+    public byte incrementAndGet() {
+        final byte newVal = ARITH.incrementAndGet(accessor.getRaw());
+        accessor.setRaw(newVal);
+        return newVal;
+    }
+
+    public byte getAndIncrement() {
+        final byte current = accessor.getRaw();
+        final byte last = ARITH.getAndIncrement(current);
+        final byte newVal = ARITH.increment(current);
+        accessor.setRaw(newVal);
+        return last;
+    }
+
+    public void decrement() {
+        accessor.setRaw(ARITH.decrement(accessor.getRaw()));
+    }
+
+    public byte decrementAndGet() {
+        final byte newVal = ARITH.decrementAndGet(accessor.getRaw());
+        accessor.setRaw(newVal);
+        return newVal;
+    }
+
+    public byte getAndDecrement() {
+        final byte current = accessor.getRaw();
+        final byte last = ARITH.getAndDecrement(current);
+        final byte newVal = ARITH.decrement(current);
+        accessor.setRaw(newVal);
+        return last;
+    }
+
+    public void subtract(final byte operand) {
+        accessor.setRaw(ARITH.subtract(accessor.getRaw(), operand));
+    }
+
+    public void subtract(final Number operand) {
+        accessor.setRaw(ARITH.subtract(accessor.getRaw(), operand));
+    }
+}
