+package org.apache.commons.lang3.mutable;
+
+/**
+ * Narrow accessor interface exposing raw get/set access to a byte storage.
+ * This is intended to decouple operation implementations from MutableByte internals.
+ *
+ * @since 3.0
+ */
+public interface MutableByteAccessor {
+
+    /**
+     * Gets the raw byte value.
+     *
+     * @return the raw byte
+     */
+    byte getRaw();
+
+    /**
+     * Sets the raw byte value.
+     *
+     * @param value the value to set
+     */
+    void setRaw(byte value);
+}
