+public abstract class FilterFileChannelAbstractBuilder<F extends FilterFileChannel, C extends FileChannel, B extends FilterFileChannelAbstractBuilder<F, C, B>>
+        extends AbstractStreamBuilder<F, FilterFileChannelAbstractBuilder<F, C, B>> {
