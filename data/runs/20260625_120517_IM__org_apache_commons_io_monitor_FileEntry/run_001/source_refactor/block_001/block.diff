+package org.apache.commons.io.monitor;
+
+import java.io.File;
+import java.io.IOException;
+import java.nio.file.Files;
+import java.nio.file.attribute.FileTime;
+
+import org.apache.commons.io.FileUtils;
+import org.apache.commons.io.file.attribute.FileTimes;
+
+public class FileAttributes {
+
+    private String name;
+    private boolean exists;
+    private boolean directory;
+    private SerializableFileTime lastModified;
+    private long length;
+
+    public FileAttributes(File file) {
+        this.name = file.getName();
+        this.exists = Files.exists(file.toPath());
+        this.directory = file.isDirectory();
+        try {
+            FileTime ft = FileUtils.lastModifiedFileTime(file);
+            this.lastModified = new SerializableFileTime(ft);
+        } catch (IOException ex) {
+            // On error, set to epoch
+            this.lastModified = new SerializableFileTime(FileTime.fromMillis(0L));
+        }
+        this.length = file.length();
+    }
+
+    public String getName() {
+        return name;
+    }
+
+    public void setName(String name) {
+        this.name = name;
+    }
+
+    public boolean isExists() {
+        return exists;
+    }
+
+    public void setExists(boolean exists) {
+        this.exists = exists;
+    }
+
+    public boolean isDirectory() {
+        return directory;
+    }
+
+    public void setDirectory(boolean directory) {
+        this.directory = directory;
+    }
+
+    public long getLength() {
+        return length;
+    }
+
+    public void setLength(long length) {
+        this.length = length;
+    }
+
+    public long getLastModified() {
+        return lastModified == null ? 0L : lastModified.toMillis();
+    }
+
+    public FileTime getLastModifiedFileTime() {
+        // Convert the stored SerializableFileTime to a FileTime to preserve API compatibility
+        return FileTime.fromMillis(getLastModified());
+    }
+
+    public void setLastModified(FileTime fileTime) {
+        this.lastModified = new SerializableFileTime(fileTime);
+    }
+
+    public void setLastModified(long time) {
+        setLastModified(FileTime.fromMillis(time));
+    }
+
+    /* package-private */ void setLastModified(SerializableFileTime time) {
+        this.lastModified = time;
+    }
+
+    /**
+     * Refresh attributes from the provided file. Returns true if any attribute changed.
+     */
+    public boolean refresh(File file) {
+        boolean changed = false;
+
+        boolean newExists = Files.exists(file.toPath());
+        if (newExists != this.exists) {
+            this.exists = newExists;
+            changed = true;
+        }
+
+        boolean newDirectory = file.isDirectory();
+        if (newDirectory != this.directory) {
+            this.directory = newDirectory;
+            changed = true;
+        }
+
+        FileTime ft;
+        try {
+            ft = FileUtils.lastModifiedFileTime(file);
+        } catch (IOException ex) {
+            ft = FileTime.fromMillis(0L);
+        }
+        SerializableFileTime newLastModified = new SerializableFileTime(ft);
+        if (this.lastModified == null) {
+            if (newLastModified != null) {
+                this.lastModified = newLastModified;
+                changed = true;
+            }
+        } else if (!this.lastModified.equals(newLastModified)) {
+            this.lastModified = newLastModified;
+            changed = true;
+        }
+
+        long newLength = file.length();
+        if (newLength != this.length) {
+            this.length = newLength;
+            changed = true;
+        }
+
+        String newName = file.getName();
+        if (newName == null) {
+            if (this.name != null) {
+                this.name = newName;
+                changed = true;
+            }
+        } else if (!newName.equals(this.name)) {
+            this.name = newName;
+            changed = true;
+        }
+
+        return changed;
+    }
+}
