+package org.apache.commons.io.monitor;
+
+import java.io.File;
+import java.nio.file.attribute.FileTime;
+
+/**
+ * Narrow interface exposing attribute accessors for a FileEntry attribute holder.
+ */
+public interface FileEntryAttributes {
+
+    long getLastModified();
+
+    FileTime getLastModifiedFileTime();
+
+    long getLength();
+
+    String getName();
+
+    boolean isDirectory();
+
+    boolean isExists();
+
+    boolean refresh(File file);
+
+    void setDirectory(boolean directory);
+
+    void setExists(boolean exists);
+
+    void setLastModified(FileTime lastModified);
+
+    void setLastModified(long lastModified);
+
+    void setLength(long length);
+
+    void setName(String name);
+}
