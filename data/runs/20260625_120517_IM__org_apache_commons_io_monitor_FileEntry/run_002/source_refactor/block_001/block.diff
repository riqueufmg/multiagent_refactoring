+ * WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.
+ * See the License for the specific language governing permissions and
+ * limitations under the License.
+ */
+package org.apache.commons.io.monitor;
+
+import java.io.File;
+import java.io.Serializable;
+import java.nio.file.attribute.FileTime;
+
+/**
+ * Helper class to hold attribute-related state for a FileEntry.
+ */
+public class FileEntryState implements Serializable {
+
+    private static final long serialVersionUID = 1L;
+
+    private final FileAttributes attributes;
+
+    public FileEntryState(final File file) {
+        this.attributes = new FileAttributes(file);
+    }
+
+    public long getLastModified() {
+        return attributes.getLastModified();
+    }
+
+    public FileTime getLastModifiedFileTime() {
+        return attributes.getLastModifiedFileTime();
+    }
+
+    public long getLength() {
+        return attributes.getLength();
+    }
+
+    public String getName() {
+        return attributes.getName();
+    }
+
+    public boolean isDirectory() {
+        return attributes.isDirectory();
+    }
+
+    public boolean isExists() {
+        return attributes.isExists();
+    }
+
+    public boolean refresh(final File file) {
+        // cache original values from attributes
+        final boolean origExists = attributes.isExists();
+        final long origLastModified = attributes.getLastModified();
+        final boolean origDirectory = attributes.isDirectory();
+        final long origLength = attributes.getLength();
+
+        // refresh attributes
+        attributes.refresh(file);
+
+        // Return if there are changes (only consider these attributes as before)
+        return attributes.isExists() != origExists
+            || attributes.getLastModified() != origLastModified
+            || attributes.isDirectory() != origDirectory
+            || attributes.getLength() != origLength;
+    }
+
+    public void setDirectory(final boolean directory) {
+        attributes.setDirectory(directory);
+    }
+
+    public void setExists(final boolean exists) {
+        attributes.setExists(exists);
+    }
+
+    public void setLastModified(final FileTime lastModified) {
+        attributes.setLastModified(lastModified);
+    }
+
+    public void setLastModified(final long lastModified) {
+        attributes.setLastModified(lastModified);
+    }
+
+    void setLastModified(final SerializableFileTime lastModified) {
+        attributes.setLastModified(lastModified);
+    }
+
+    public void setLength(final long length) {
+        attributes.setLength(length);
+    }
+
+    public void setName(final String name) {
+        attributes.setName(name);
+    }
+}
