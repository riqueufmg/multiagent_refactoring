diff --git a/src/main/java/org/apache/commons/lang3/reflect/MethodUtilsCore.java b/src/main/java/org/apache/commons/lang3/reflect/MethodUtilsCore.java
new file mode 100644
index 000000000..67eb68846
--- /dev/null
+++ b/src/main/java/org/apache/commons/lang3/reflect/MethodUtilsCore.java
@@ -0,0 +1,134 @@
+/*
