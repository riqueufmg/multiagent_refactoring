+package org.apache.commons.lang3;
+
+/**
+ * Helper class encapsulating boolean/bit-flag operations for a BitField mask.
+ * This extraction reduces complexity in BitField by delegating simple flag
+ * operations to this helper while preserving BitField's public API.
+ */
+final class BitFieldBooleanOps {
+
+    private final long mask;
+
+    BitFieldBooleanOps(final long mask) {
+        this.mask = mask;
+    }
+
+    boolean isAllSet(final int holder) {
+        return (holder & mask) == mask;
+    }
+
+    boolean isAllSet(final long holder) {
+        return (holder & mask) == mask;
+    }
+
+    boolean isSet(final int holder) {
+        return (holder & mask) != 0;
+    }
+
+    boolean isSet(final long holder) {
+        return (holder & mask) != 0;
+    }
+
+    int set(final int holder) {
+        return (int) (holder | mask);
+    }
+
+    long set(final long holder) {
+        return holder | mask;
+    }
+
+    int setBoolean(final int holder, final boolean flag) {
+        return flag ? set(holder) : (int) (holder & ~mask);
+    }
+
+    long setBoolean(final long holder, final boolean flag) {
+        return flag ? set(holder) : (holder & ~mask);
+    }
+}
