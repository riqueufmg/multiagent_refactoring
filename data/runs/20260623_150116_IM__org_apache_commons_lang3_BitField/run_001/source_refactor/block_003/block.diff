+package org.apache.commons.lang3;
+
+/**
+ * Extracted core masking logic that operates on int/long holders.
+ * This class is package-private and intended to be used by BitField to delegate
+ * the primitive int/long masking operations.
+ */
+class BitFieldCore {
+
+    private final long mask;
+    private final int shiftCount;
+
+    BitFieldCore(final long mask, final int shiftCount) {
+        this.mask = mask;
+        this.shiftCount = shiftCount;
+    }
+
+    int clear(final int holder) {
+        return (int) (holder & ~mask);
+    }
+
+    long clear(final long holder) {
+        return holder & ~mask;
+    }
+
+    int getRawValue(final int holder) {
+        return (int) (holder & mask);
+    }
+
+    long getRawValue(final long holder) {
+        return holder & mask;
+    }
+
+    int getValue(final int holder) {
+        return getRawValue(holder) >> shiftCount;
+    }
+
+    long getValue(final long holder) {
+        return getRawValue(holder) >> shiftCount;
+    }
+
+    int setValue(final int holder, final int value) {
+        return (int) (holder & ~mask | value << shiftCount & mask);
+    }
+
+    long setValue(final long holder, final long value) {
+        return holder & ~mask | value << shiftCount & mask;
+    }
+}
