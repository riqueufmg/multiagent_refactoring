@@ -0,0 +1,69 @@
+package org.jsoup.nodes;
+
+import org.jsoup.helper.Validate;
+import org.jsoup.select.Collector;
+import org.jsoup.select.Elements;
+import org.jsoup.select.Evaluator;
+import org.jsoup.select.Selector;
+import org.jsoup.select.Nodes;
+import java.util.List;
+import java.util.stream.Stream;
+import org.jspecify.annotations.Nullable;
+
+/**
+ * Helper class that contains selection/query implementations extracted from Element.
+ * The methods are static and take an Element context, to avoid Element having heavy selector logic directly.
+ */
+public final class ElementQuerySupport {
+    private ElementQuerySupport() {}
+
+    public static Elements select(Element el, String cssQuery) {
+        return Selector.select(cssQuery, el);
+    }
+
+    public static Elements select(Element el, Evaluator evaluator) {
+        return Selector.select(evaluator, el);
+    }
+
+    public static Stream<Element> selectStream(Element el, String cssQuery) {
+        return Selector.selectStream(cssQuery, el);
+    }
+
+    public static Stream<Element> selectStream(Element el, Evaluator evaluator) {
+        return Selector.selectStream(evaluator, el);
+    }
+
+    public static @Nullable Element selectFirst(Element el, String cssQuery) {
+        return Selector.selectFirst(cssQuery, el);
+    }
+
+    public static @Nullable Element selectFirst(Element el, Evaluator evaluator) {
+        return Collector.findFirst(evaluator, el);
+    }
+
+    public static Nodes<Node> selectNodes(Element el, Evaluator evaluator) {
+        return selectNodes(el, evaluator, Node.class);
+    }
+
+    public static Nodes<Node> selectNodes(Element el, String cssQuery) {
+        Validate.notEmpty(cssQuery);
+        return selectNodes(el, Selector.evaluatorOf(cssQuery), Node.class);
+    }
+
+    public static <T extends Node> Nodes<T> selectNodes(Element el, Evaluator evaluator, Class<T> type) {
+        Validate.notNull(evaluator);
+        return Collector.collectNodes(evaluator, el, type);
+    }
+
+    public static @Nullable <T extends Node> T selectFirstNode(Element el, String cssQuery, Class<T> type) {
+        return selectFirstNode(el, Selector.evaluatorOf(cssQuery), type);
+    }
+
+    public static @Nullable <T extends Node> T selectFirstNode(Element el, Evaluator evaluator, Class<T> type) {
+        return Collector.findFirstNode(evaluator, el, type);
+    }
+
+    public static Elements selectXpath(Element el, String xpath) {
+        return new Elements(NodeUtils.selectXpath(xpath, el, Element.class));
+    }
+}
