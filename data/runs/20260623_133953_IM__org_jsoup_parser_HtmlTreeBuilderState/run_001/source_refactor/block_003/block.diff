+package org.jsoup.parser;
+
+/**
+ * Thin facade to centralize external calls into HtmlTreeBuilderState. Provides a single
+ * stable entry point for handling tokens against a given state. Delegates to the
+ * enum's package-private process(...) method.
+ */
+public final class HtmlTreeBuilderStateFacade {
+
+    private HtmlTreeBuilderStateFacade() {
+        // no instantiation
+    }
+
+    /**
+     * Handle a token using the provided state by delegating to HtmlTreeBuilderState.process.
+     *
+     * @param t the token to process
+     * @param tb the tree builder
+     * @param state the current state
+     * @return true if processing should continue, false otherwise
+     */
+    public static boolean handle(Token t, HtmlTreeBuilder tb, HtmlTreeBuilderState state) {
+        return state.process(t, tb);
+    }
+}
