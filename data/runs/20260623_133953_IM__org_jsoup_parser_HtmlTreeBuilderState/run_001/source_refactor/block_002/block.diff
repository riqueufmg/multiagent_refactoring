diff --git a/src/main/java/org/jsoup/parser/HtmlTreeBuilderStateHelper.java b/src/main/java/org/jsoup/parser/HtmlTreeBuilderStateHelper.java
new file mode 100644
index 00000000..c55a8091
--- /dev/null
+++ b/src/main/java/org/jsoup/parser/HtmlTreeBuilderStateHelper.java
@@ -0,0 +1,50 @@
+package org.jsoup.parser;
+
+import org.jsoup.internal.StringUtil;
+import org.jsoup.nodes.Attribute;
+import org.jsoup.nodes.Attributes;
+import org.jsoup.nodes.Element;
+import org.jsoup.nodes.NodeInternals;
+import org.jsoup.nodes.Range;
+import org.jspecify.annotations.Nullable;
+
+/**
+ * Helper utilities extracted from HtmlTreeBuilderState to reduce enum complexity.
+ */
+public final class HtmlTreeBuilderStateHelper {
+
+    private HtmlTreeBuilderStateHelper() {
+        // no instantiation
+    }
+
+    public static void mergeAttributes(Token.StartTag source, Element dest) {
+        if (!source.hasAttributes()) return;
+        source.finaliseAttributeRanges(source.treeBuilder.settings);
+        for (Attribute attr : source.attributes) { // only iterates public attributes
+            Attributes destAttrs = dest.attributes();
+            if (!destAttrs.hasKey(attr.getKey())) {
+                Range.AttributeRange range = attr.sourceRange(); // grab before its parent changes
+                destAttrs.put(attr);
+                NodeInternals.attributeRange(destAttrs, attr.getKey(), range);
+            }
+        }
+    }
+
+    public static final String nullString = String.valueOf('\u0000');
+
+    public static boolean isWhitespace(Token t) {
+        if (t.isCharacter()) {
+            String data = t.asCharacter().getData();
+            return StringUtil.isBlank(data);
+        }
+        return false;
+    }
+
+    public static void HandleTextState(Token.StartTag startTag, HtmlTreeBuilder tb, @Nullable TokeniserState state) {
+        if (state != null)
+            tb.tokeniser.transition(state);
+        tb.markInsertionMode();
+        tb.transition(HtmlTreeBuilderState.Text);
+        tb.insertElementFor(startTag);
+    }
+}
