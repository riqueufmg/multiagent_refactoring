+++ b/src/main/java/org/jsoup/parser/TokeniserStateDataFacade.java
@@ -0,0 +1,82 @@
+package org.jsoup.parser;
+
+/**
+ * Facade to hold data-related Tokeniser state logic extracted from TokeniserState enum.
+ */
+final class TokeniserStateDataFacade {
+    private TokeniserStateDataFacade() {}
+
+    static void readData(Tokeniser t, CharacterReader r) {
+        switch (r.current()) {
+            case '&':
+                t.advanceTransition(TokeniserState.CharacterReferenceInData);
+                break;
+            case '<':
+                t.advanceTransition(TokeniserState.TagOpen);
+                break;
+            case TokeniserState.nullChar:
+                t.error(TokeniserState.Data); // NOT replacement character (oddly?)
+                t.emit(r.consume());
+                break;
+            case TokeniserStateHelper.EOF:
+                t.emit(new Token.EOF());
+                break;
+            default:
+                String data = r.consumeData();
+                t.emit(data);
+                break;
+        }
+    }
+
+    static void readCharRefInData(Tokeniser t, CharacterReader r) {
+        TokeniserStateHelper.readCharRef(t, TokeniserState.Data);
+    }
+
+    static void readRcdata(Tokeniser t, CharacterReader r) {
+        switch (r.current()) {
+            case '&':
+                t.advanceTransition(TokeniserState.CharacterReferenceInRcdata);
+                break;
+            case '<':
+                t.advanceTransition(TokeniserState.RcdataLessthanSign);
+                break;
+            case TokeniserState.nullChar:
+                t.error(TokeniserState.Rcdata);
+                r.advance();
+                t.emit(TokeniserStateHelper.replacementChar());
+                break;
+            case TokeniserStateHelper.EOF:
+                t.emit(new Token.EOF());
+                break;
+            default:
+                String data = r.consumeData();
+                t.emit(data);
+                break;
+        }
+    }
+
+    static void readCharRefInRcdata(Tokeniser t, CharacterReader r) {
+        TokeniserStateHelper.readCharRef(t, TokeniserState.Rcdata);
+    }
+
+    static void readRawtext(Tokeniser t, CharacterReader r) {
+        TokeniserStateHelper.readRawData(t, r, TokeniserState.Rawtext, TokeniserState.RawtextLessthanSign);
+    }
+
+    static void readPlaintext(Tokeniser t, CharacterReader r) {
+        switch (r.current()) {
+            case TokeniserState.nullChar:
+                t.error(TokeniserState.PLAINTEXT);
+                r.advance();
+                t.emit(TokeniserStateHelper.replacementChar());
+                break;
+            case TokeniserStateHelper.EOF:
+                t.emit(new Token.EOF());
+                break;
+            default:
+                String data = r.consumeTo(TokeniserState.nullChar);
+                t.emit(data);
+                break;
+        }
+    }
+}
