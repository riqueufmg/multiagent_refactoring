diff --git a/src/main/java/org/jsoup/parser/TokeniserStateTagFacade.java b/src/main/java/org/jsoup/parser/TokeniserStateTagFacade.java
new file mode 100644
index 00000000..771d8f00
--- /dev/null
+++ b/src/main/java/org/jsoup/parser/TokeniserStateTagFacade.java
@@ -0,0 +1,101 @@
+package org.jsoup.parser;
+
+import static org.jsoup.nodes.Document.OutputSettings.Syntax.xml;
+
+final class TokeniserStateTagFacade {
+
+    private TokeniserStateTagFacade() {}
+
+    static void readTagOpen(Tokeniser t, CharacterReader r) {
+        switch (r.current()) {
+            case '!':
+                t.advanceTransition(TokeniserState.MarkupDeclarationOpen);
+                break;
+            case '/':
+                t.advanceTransition(TokeniserState.EndTagOpen);
+                break;
+            case '?':
+                if (t.syntax == xml) {
+                    t.advanceTransition(TokeniserState.MarkupProcessingOpen);
+                } else {
+                    t.createBogusCommentPending();
+                    t.transition(TokeniserState.BogusComment);
+                }
+                break;
+            default:
+                if (r.matchesAsciiAlpha()) {
+                    t.createTagPending(true);
+                    t.transition(TokeniserState.TagName);
+                } else {
+                    t.error(TokeniserState.TagOpen);
+                    t.emit('<'); // char that got us here
+                    t.transition(TokeniserState.Data);
+                }
+                break;
+        }
+    }
+
+    static void readEndTagOpen(Tokeniser t, CharacterReader r) {
+        if (r.isEmpty()) {
+            t.eofError(TokeniserState.EndTagOpen);
+            t.emit("</");
+            t.transition(TokeniserState.Data);
+        } else if (r.matchesAsciiAlpha()) {
+            t.createTagPending(false);
+            t.transition(TokeniserState.TagName);
+        } else if (r.matches('/')) {
+            // Note: original had matches('>') here; preserving semantics but checking for '>' explicitly
+            // If it's a '>' token, it's an error and we advance to Data
+            if (r.matches('>')) {
+                t.error(TokeniserState.EndTagOpen);
+                t.advanceTransition(TokeniserState.Data);
+            } else {
+                t.error(TokeniserState.EndTagOpen);
+                t.createBogusCommentPending();
+                t.commentPending.append('/'); // push the / back on that got us here
+                t.transition(TokeniserState.BogusComment);
+            }
+        } else if (r.matches('>')) {
+            t.error(TokeniserState.EndTagOpen);
+            t.advanceTransition(TokeniserState.Data);
+        } else {
+            t.error(TokeniserState.EndTagOpen);
+            t.createBogusCommentPending();
+            t.commentPending.append('/'); // push the / back on that got us here
+            t.transition(TokeniserState.BogusComment);
+        }
+    }
+
+    static void readTagName(Tokeniser t, CharacterReader r) {
+        // previous TagOpen state did NOT consume, will have a letter char in current
+        String tagName = r.consumeTagName();
+        t.tagPending.appendTagName(tagName);
+
+        char c = r.consume();
+        switch (c) {
+            case '\t':
+            case '\n':
+            case '\r':
+            case '\f':
+            case ' ':
+                t.transition(TokeniserState.BeforeAttributeName);
+                break;
+            case '/':
+                t.transition(TokeniserState.SelfClosingStartTag);
+                break;
+            case '>':
+                t.emitTagPending();
+                t.transition(TokeniserState.Data);
+                break;
+            case TokeniserState.nullChar: // replacement
+                t.tagPending.appendTagName(TokeniserStateHelper.replacementStr());
+                break;
+            case TokeniserStateHelper.EOF: // should emit pending tag?
+                t.eofError(TokeniserState.TagName);
+                t.transition(TokeniserState.Data);
+                break;
+            default: // buffer underrun
+                t.tagPending.appendTagName(c);
+        }
+    }
+}
